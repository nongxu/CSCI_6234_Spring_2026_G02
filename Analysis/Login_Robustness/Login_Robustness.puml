@startuml
left to right direction

title Login

actor Customer

' Boundary Object
boundary "Login Form" as loginForm 

' Control Object
control "Authentication Controller" as authControl

' Entity Object
entity "Customer Data" as customerEntity

' Relationships
Customer -- loginForm : interacts with
loginForm -- authControl : submits credentials to
authControl -- customerEntity : authenticates against

note bottom of loginForm
    User interface for
    entering login credentials
end note

note bottom of authControl
    Validates credentials and
    manages user sessions
end note

note bottom of customerEntity
    Stores user credentials
    and account information
end note

@enduml