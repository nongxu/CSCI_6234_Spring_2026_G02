@startuml
title Checkout Order

actor Customer

' Boundary Object
boundary "Checkout Interface" as checkoutUI

' Control Object
control "Authentication Controller" as authCtrl
control "Checkout Controller" as checkoutCtrl

' Entity Object
entity "Customer" as customerEntity
entity "Cart" as cart

' Flow - Authentication
Customer -> checkoutUI : initiate checkout
checkoutUI -> authCtrl : verify user
authCtrl -> customerEntity : check authentication
customerEntity -> authCtrl : authenticated
authCtrl -> checkoutUI : proceed

' Flow - Checkout
checkoutUI -> checkoutCtrl : request cart contents
checkoutCtrl -> cart : retrieve cart
cart -> checkoutCtrl : cart data
checkoutCtrl -> checkoutUI : display order summary
checkoutUI -> Customer : show summary
Customer -> checkoutUI : confirm order
checkoutUI ->checkoutCtrl : process checkout
checkoutCtrl -> cart : finalize order
cart -> checkoutCtrl : order completed
checkoutCtrl -> checkoutUI : confirmation
checkoutUI -> Customer : show confirmation

@enduml