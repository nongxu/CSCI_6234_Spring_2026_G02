@startuml
left to right direction

title Sign Up

actor Customer

' Boundary Objects
boundary "Sign Up Form" as signupform

' Control Objects
control "Registration Controller" as controller

' Entity Objects
entity "Customer Data" as customerEntity

' Relationships
Customer -- signupform : interacts with
signupform -- controller : submits data to
controller -- customerEntity : validates and creates

note bottom of signupform
    User interface for 
    collection registration 
    information
end note

note bottom of controller
    Handles registration logic,
    validates data and creates
    new customer accounts
end note

note bottom of customerEntity
    Stores customer
    information persistently
end note

@enduml