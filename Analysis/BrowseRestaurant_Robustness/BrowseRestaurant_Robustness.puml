@startuml
left to right direction

title Browse Restaurant

actor Customer

' Boundary Object
boundary "Restaurant List Page" as restaurantList
boundary "Menu Page" as menuPage

' Control Object
control "Restaurant Controller" as restaurantCtrol
control "Menu Controller" as menuCtrl

' Entity Object
entity "Restaurant Data" as restaurant
entity "MenuItem Data" as menuItem

' Relationships
Customer -- restaurantList : browses
Customer -- menuPage : views
restaurantList -- restaurantCtrol : requests data from
menuPage -- menuCtrl : requests data from
restaurantCtrol -- restaurant : retrieves from
menuCtrl -- menuItem : retrieves from

note bottom of restaurantList
    Displays list of 
    available restaurants
end note

note bottom of menuPage
    Displays menu items
    for selected restaurant
end note

note bottom of restaurantCtrol
    Manages restaurant
    data retrieval
end note

note bottom of menuCtrl
    Manages menu
    data retrieval
end note

@enduml